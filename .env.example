# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Linear
LINEAR_API_KEY=lin_api_your_linear_api_key
LINEAR_TEAM_ID=your_linear_team_id

# App
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Optional: security team notification
SECURITY_LABEL_ID=

# Comma-separated GitHub usernames who can override checks (e.g. "alice,bob")
OVERRIDE_USERS=
# Name shown on the GitHub commit status check
STATUS_CONTEXT=GitGuardian
